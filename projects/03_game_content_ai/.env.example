# ゲームニュース記事生成ツール - 環境変数設定例
# このファイルをコピーして .env にリネームし、実際のAPIキーを入力してください。
# .env は .gitignore で管理されているため、GitHubにはアップロードされません。

# Anthropic API キー（必須）
# https://console.anthropic.com/ から取得してください
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WordPress REST API 設定（WordPressへの下書き投稿を使う場合のみ設定）
# 未設定の場合は WordPress 投稿がスキップされ、Markdown 保存のみ動作します
# WP_SITE_URL=https://your-wordpress-site.com
# WP_USERNAME=your_wp_username
# WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress アイキャッチ画像のデフォルト Media ID（v1.6.0 追加）
# WordPress メディアライブラリにアップロードした画像の ID を設定してください。
# 設定方法: WordPress管理画面 → メディア → 画像を選択 → URLの ?item=XXXX の数字
# 0 の場合はアイキャッチなしで投稿されます（従来動作）
# DEFAULT_MEDIA_ID=0

# ─────────────────────────────────────────
# Publishing Automation（v1.7.0 追加）
# ─────────────────────────────────────────
# 重要度ごとの WordPress 投稿ステータスを設定します。
# 使用可能な値:
#   draft   - 下書き（デフォルト。未設定時もこの動作になります）
#   pending - レビュー待ち（WordPress管理画面で「公開」ボタンを押すまで非公開）
# 無効な値を設定した場合は自動的に "draft" にフォールバックします。
#
# 設定例（S評価記事だけレビュー待ちにしたい場合）:
#   PUBLISH_STATUS_S=pending
#   PUBLISH_STATUS_A=draft
PUBLISH_STATUS_S=draft
PUBLISH_STATUS_A=draft

# ─────────────────────────────────────────
# Logging（v1.8.0 追加）
# ─────────────────────────────────────────
# ログ出力の有効/無効
# true  : logs/ フォルダに実行ログを保存する（デフォルト）
# false : ログを一切保存しない（v1.7.0 以前と同じ動作）
LOG_ENABLED=true

# ログの保存先ディレクトリ（main.py からの相対パス）
# デフォルト: logs（projects/03_game_content_ai/logs/ に保存されます）
LOG_DIR=logs

# ─────────────────────────────────────────
# Execution History Foundation（v2.8.0 追加）
# ─────────────────────────────────────────
# Workflow Engine（v2.7.0）が実行したWorkflowの履歴記録の有効/無効
# true  : logs/execution_history/ へ実行履歴（JSON）を保存する（デフォルト）
# false : 履歴を一切保存しない
# ローカルJSONファイルへの記録のみで外部への副作用を持たないため、LOG_ENABLEDと同じく
# デフォルト有効としています（AI_AGENT_ENABLED等のAgent系ゲートとは性質が異なります）。
EXECUTION_HISTORY_ENABLED=true

# 履歴の保存先ディレクトリ（このファイルがあるディレクトリからの相対パス）
# デフォルト: logs/execution_history
# EXECUTION_HISTORY_DIR=logs/execution_history

# ─────────────────────────────────────────
# SNS Foundation（v1.9.0 追加）
# ─────────────────────────────────────────
# ブログの公開URL（X投稿文に記事URLを埋め込む場合に設定）
# WordPress のパーマリンク設定が「投稿名（/%postname%/）」形式であることが前提です。
# 設定例: BLOG_BASE_URL=https://your-blog.com
# 未設定の場合は X投稿文に "[ブログURL]" というプレースホルダーが残ります。
# ※ WP_SITE_URL が設定済みであれば、そちらを自動でフォールバックとして使用します。
# BLOG_BASE_URL=https://your-blog.com

# SNS 機能の有効/無効
# true  : X投稿文の生成と wp_public_url の計算を行う（デフォルト）
# false : SNS機能をスキップ。x_post_status は "skipped" になります。
SNS_ENABLED=true

# ─────────────────────────────────────────
# Analytics Foundation（v1.10.0 追加）
# ─────────────────────────────────────────
# Analytics 機能の有効/無効
# false : Analytics機能を無効にする（デフォルト）
#         ※ Logging Foundation（LOG_ENABLED）は基本動作のためデフォルト有効ですが、
#           Analytics Foundation は外部API連携・分析処理へ発展する基盤のため、
#           v1.10.0 では意図的にデフォルト無効とします。
# true  : AnalyticsManager を有効化（logs/analytics/ へのデータ蓄積を開始）
ANALYTICS_ENABLED=false

# Analytics ログの保存先サブディレクトリ（LOG_DIR 配下。デフォルト: analytics）
# 有効時: logs/analytics/YYYYMMDD_analytics.jsonl に保存されます。
# ANALYTICS_DIR=analytics

# パフォーマンスデータの計測期間（日数。デフォルト: 28）
# Search Console / Google Analytics からデータを取得する際の集計期間に使用します。
# ANALYTICS_PERIOD_DAYS=28

# ─────────────────────────────────────────
# Search Console Foundation（v1.12.0 追加）
# ─────────────────────────────────────────
# Search Console 機能の有効/無効
# false : Search Console機能を無効にする（デフォルト）
#         ※ 投稿直後はSearch Consoleデータが存在しないため、
#           データ取得は別スクリプト（scripts/fetch_search_console_metrics.py）で行います。
# true  : SearchConsoleClient を有効化（APIキー・認証情報の設定が必要）
SEARCH_CONSOLE_ENABLED=false

# Search Console のプロパティURL（サイトのルートURL）
# Search Console で「URL プレフィックス」タイプで登録したURLを指定してください。
# 例: SEARCH_CONSOLE_PROPERTY=https://your-blog.com/
# SEARCH_CONSOLE_PROPERTY=https://your-blog.com/

# Google Service Account 認証情報ファイルのパス
# Google Cloud Console でサービスアカウントを作成し、JSONキーをダウンロードして配置してください。
# 配置先: projects/03_game_content_ai/credentials/search_console_sa.json
# ※ credentials/ ディレクトリは .gitignore で除外されています（GitHubにはアップロードされません）。
# GOOGLE_APPLICATION_CREDENTIALS=credentials/search_console_sa.json

# Search Console API のタイムアウト秒数（デフォルト: 30）
# SEARCH_CONSOLE_TIMEOUT=30

# ─────────────────────────────────────────
# Google Analytics Foundation（v1.13.0 追加）
# ─────────────────────────────────────────
# Google Analytics 4 機能の有効/無効
# false : GA4機能を無効にする（デフォルト）
#         ※ 投稿直後はGA4データが存在しないため、
#           データ取得は別スクリプト（scripts/fetch_google_analytics_metrics.py）で行います。
# true  : GoogleAnalyticsClient を有効化（APIキー・認証情報の設定が必要）
GOOGLE_ANALYTICS_ENABLED=false

# GA4 プロパティID（Google Analytics 管理画面で確認できる数値ID）
# 例: GA4_PROPERTY_ID=123456789
# GA4_PROPERTY_ID=123456789

# GA4 Service Account 認証情報ファイルのパス
# Search Console とは別の Service Account を使用できます。
# 配置先: projects/03_game_content_ai/credentials/google_analytics_sa.json
# ※ credentials/ ディレクトリは .gitignore で除外されています（GitHubにはアップロードされません）。
# GA4_APPLICATION_CREDENTIALS=credentials/google_analytics_sa.json

# GA4 API のタイムアウト秒数（デフォルト: 30）
# GA4_TIMEOUT_SECONDS=30

# パフォーマンスデータの計測期間（日数）は Search Console と共通です。
# ANALYTICS_PERIOD_DAYS=28

# ─────────────────────────────────────────
# AI Improvement Foundation（v1.14.0 追加）
# ─────────────────────────────────────────
# AI 改善提案機能の有効/無効
# false : AI改善提案機能を無効にする（デフォルト）
#         ※ 投稿直後ではなく、SC/GA4データ取得後に別スクリプトで実行する設計です。
#           有効化には ANTHROPIC_API_KEY の設定も必要です。
# true  : AiImprovementService を有効化（Anthropic APIキーの設定が必要）
AI_IMPROVEMENT_ENABLED=false

# 使用する Claude モデル（デフォルト: claude-sonnet-4-6）
# 利用可能なモデル例: claude-haiku-4-5-20251001（低コスト）/ claude-sonnet-4-6（高品質）
# AI_IMPROVEMENT_MODEL=claude-sonnet-4-6

# プロンプトバージョン（デフォルト: v1）
# バージョン管理: src/ai/prompts/v1_improvement.py に対応
# AI_IMPROVEMENT_PROMPT_VERSION=v1

# 1バッチあたりの最大処理件数（デフォルト: 10）
# APIコスト管理のため、大量の記事を一度に処理しないよう上限を設定します。
# AI_IMPROVEMENT_MAX_ARTICLES=10

# 改善提案 JSON の保存先ディレクトリ（main.py からの相対パス）
# デフォルト: outputs/ai_improvements（YYYYMMDD_{slug}_improvement.json として保存）
# AI_IMPROVEMENT_OUTPUT_DIR=outputs/ai_improvements

# AI API タイムアウト秒数（デフォルト: 60）
# AI_TIMEOUT_SECONDS=60

# ※ ANTHROPIC_API_KEY は上記「Anthropic API キー（必須）」セクションで設定します。
#   AI_IMPROVEMENT_ENABLED=true の場合も同じキーを使用します。

# ─────────────────────────────────────────
# Image Generation Configuration Gate（v6.15.0 追加）
# ─────────────────────────────────────────
# 画像生成機能（AIImageGenerator Protocol）を有効化の対象とするかどうかのGateです。
# true  : 画像生成機能を有効化の対象とする
# false : 画像生成機能を無効化する（デフォルト。未設定時もこの動作になります）
#         true以外の値（1 / yes / on 等を含む）はすべて false と同じ扱いになります。
# ※ v6.15.0時点では、このGateを読み取って画像生成を実行するRuntime連携は
#   まだ実装されていません（Consumer-less Foundation）。true に設定しても、
#   本設定単独では画像生成は一切実行されません。
AI_IMAGE_GENERATION_ENABLED=false

# OpenAI Images API キー（画像生成機能を将来利用する場合のみ設定）
# AI_IMAGE_GENERATION_ENABLED とは別の設定であり、この値だけでは画像生成は
# 実行されません。https://platform.openai.com/api-keys から取得してください
# OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Images API のタイムアウト秒数（デフォルト: 180）
# OPENAI_IMAGE_TIMEOUT_SECONDS=180
