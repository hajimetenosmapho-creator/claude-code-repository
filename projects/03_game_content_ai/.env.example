# ゲームニュース記事生成ツール - 環境変数設定例
# このファイルをコピーして .env にリネームし、実際のAPIキーを入力してください。
# .env は .gitignore で管理されているため、GitHubにはアップロードされません。

# Anthropic API キー（必須）
# https://console.anthropic.com/ から取得してください
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WordPress REST API 設定（WordPressへの下書き投稿を使う場合のみ設定）
# 未設定の場合は WordPress 投稿がスキップされ、Markdown 保存のみ動作します
# WP_SITE_URL=https://your-wordpress-site.com
# WP_USERNAME=your_wp_username
# WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress アイキャッチ画像のデフォルト Media ID（v1.6.0 追加）
# WordPress メディアライブラリにアップロードした画像の ID を設定してください。
# 設定方法: WordPress管理画面 → メディア → 画像を選択 → URLの ?item=XXXX の数字
# 0 の場合はアイキャッチなしで投稿されます（従来動作）
# DEFAULT_MEDIA_ID=0

# ─────────────────────────────────────────
# Publishing Automation（v1.7.0 追加）
# ─────────────────────────────────────────
# 重要度ごとの WordPress 投稿ステータスを設定します。
# 使用可能な値:
#   draft   - 下書き（デフォルト。未設定時もこの動作になります）
#   pending - レビュー待ち（WordPress管理画面で「公開」ボタンを押すまで非公開）
# 無効な値を設定した場合は自動的に "draft" にフォールバックします。
#
# 設定例（S評価記事だけレビュー待ちにしたい場合）:
#   PUBLISH_STATUS_S=pending
#   PUBLISH_STATUS_A=draft
PUBLISH_STATUS_S=draft
PUBLISH_STATUS_A=draft

# ─────────────────────────────────────────
# Logging（v1.8.0 追加）
# ─────────────────────────────────────────
# ログ出力の有効/無効
# true  : logs/ フォルダに実行ログを保存する（デフォルト）
# false : ログを一切保存しない（v1.7.0 以前と同じ動作）
LOG_ENABLED=true

# ログの保存先ディレクトリ（main.py からの相対パス）
# デフォルト: logs（projects/03_game_content_ai/logs/ に保存されます）
LOG_DIR=logs

# ─────────────────────────────────────────
# SNS Foundation（v1.9.0 追加）
# ─────────────────────────────────────────
# ブログの公開URL（X投稿文に記事URLを埋め込む場合に設定）
# WordPress のパーマリンク設定が「投稿名（/%postname%/）」形式であることが前提です。
# 設定例: BLOG_BASE_URL=https://your-blog.com
# 未設定の場合は X投稿文に "[ブログURL]" というプレースホルダーが残ります。
# ※ WP_SITE_URL が設定済みであれば、そちらを自動でフォールバックとして使用します。
# BLOG_BASE_URL=https://your-blog.com

# SNS 機能の有効/無効
# true  : X投稿文の生成と wp_public_url の計算を行う（デフォルト）
# false : SNS機能をスキップ。x_post_status は "skipped" になります。
SNS_ENABLED=true

# ─────────────────────────────────────────
# Analytics Foundation（v1.10.0 追加）
# ─────────────────────────────────────────
# Analytics 機能の有効/無効
# false : Analytics機能を無効にする（デフォルト）
#         ※ Logging Foundation（LOG_ENABLED）は基本動作のためデフォルト有効ですが、
#           Analytics Foundation は外部API連携・分析処理へ発展する基盤のため、
#           v1.10.0 では意図的にデフォルト無効とします。
# true  : AnalyticsManager を有効化（logs/analytics/ へのデータ蓄積を開始）
ANALYTICS_ENABLED=false

# Analytics ログの保存先サブディレクトリ（LOG_DIR 配下。デフォルト: analytics）
# 有効時: logs/analytics/YYYYMMDD_analytics.jsonl に保存されます。
# ANALYTICS_DIR=analytics

# パフォーマンスデータの計測期間（日数。デフォルト: 28）
# Search Console / Google Analytics からデータを取得する際の集計期間に使用します。
# ANALYTICS_PERIOD_DAYS=28

# ─────────────────────────────────────────
# Search Console Foundation（v1.12.0 追加）
# ─────────────────────────────────────────
# Search Console 機能の有効/無効
# false : Search Console機能を無効にする（デフォルト）
#         ※ 投稿直後はSearch Consoleデータが存在しないため、
#           データ取得は別スクリプト（scripts/fetch_search_console_metrics.py）で行います。
# true  : SearchConsoleClient を有効化（APIキー・認証情報の設定が必要）
SEARCH_CONSOLE_ENABLED=false

# Search Console のプロパティURL（サイトのルートURL）
# Search Console で「URL プレフィックス」タイプで登録したURLを指定してください。
# 例: SEARCH_CONSOLE_PROPERTY=https://your-blog.com/
# SEARCH_CONSOLE_PROPERTY=https://your-blog.com/

# Google Service Account 認証情報ファイルのパス
# Google Cloud Console でサービスアカウントを作成し、JSONキーをダウンロードして配置してください。
# 配置先: projects/03_game_content_ai/credentials/search_console_sa.json
# ※ credentials/ ディレクトリは .gitignore で除外されています（GitHubにはアップロードされません）。
# GOOGLE_APPLICATION_CREDENTIALS=credentials/search_console_sa.json

# Search Console API のタイムアウト秒数（デフォルト: 30）
# SEARCH_CONSOLE_TIMEOUT=30
